# ════════════════════════════════════════════════════════
# IT Monitor Bot — ตัวแปรสภาพแวดล้อม
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริงก่อนรัน
# สร้างได้ผ่าน Setup UI ที่ http://localhost:3000/setup
# ════════════════════════════════════════════════════════

# ── LINE Messaging API ────────────────────────────────────
# หาได้จาก LINE Developers Console > channel > Basic settings
LINE_CHANNEL_SECRET=
# หาได้จาก LINE Developers Console > channel > Messaging API > Channel access token
LINE_CHANNEL_ACCESS_TOKEN=

# ── Zabbix ────────────────────────────────────────────────
# URL ของ Zabbix API เช่น http://192.168.1.10/api_jsonrpc.php
ZABBIX_URL=
# API Token: Zabbix > Administration > API tokens
ZABBIX_API_TOKEN=

# ── TP-Link Omada Controller ──────────────────────────────
# URL ของ Omada Controller เช่น https://192.168.1.20:8043
OMADA_URL=
# ชื่อผู้ใช้ Omada (แนะนำให้สร้าง account แยกสำหรับ Bot)
OMADA_USERNAME=
OMADA_PASSWORD=
# Site ID: ดูได้จาก URL ของ Omada หลัง /site/
OMADA_SITE_ID=
# Path ของ CA cert สำหรับ self-signed TLS (เว้นว่างถ้าใช้ cert จริง)
# Docker: ใส่ path ภายใน container เช่น /certs/omada-ca.crt
OMADA_CA_CERT_PATH=

# ── HikCentral ───────────────────────────────────────────
# URL ของ HikCentral เช่น http://192.168.1.30
HIKCENTRAL_URL=
# OAuth2 Client credentials: HikCentral > System > API Client
HIKCENTRAL_CLIENT_ID=
HIKCENTRAL_CLIENT_SECRET=

# ── Claude AI (Anthropic) ─────────────────────────────────
# API Key: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────────────
# Port ที่ Bot จะรัน (default: 3000)
PORT=3000

# ── Security ─────────────────────────────────────────────
# IP prefix ที่อนุญาต เช่น 192.168.1. (เว้นว่างเพื่อรับทุก IP)
ALLOWED_IP_PREFIX=
# Secret สำหรับยืนยัน Zabbix Webhook — ใช้ค่าสุ่มยาวๆ เช่น openssl rand -hex 32
# ต้องตั้งค่า header  x-zabbix-secret  ฝั่ง Zabbix ให้ตรงกัน
ZABBIX_WEBHOOK_SECRET=

# ── Setup UI ──────────────────────────────────────────────
# Password hash ของ Setup UI (SHA-256) — ตั้งได้ผ่าน Setup Wizard
# ถ้าไม่ตั้ง default password คือ "admin"
SETUP_PASSWORD_HASH=

# ── AI Quota ─────────────────────────────────────────────
# จำนวนครั้งที่แต่ละ user ใช้ AI ได้ต่อวัน (default: 20)
AI_DAILY_QUOTA=20

# ── Cloudflare Tunnel (Docker deployment เท่านั้น) ────────
# Token จาก https://one.dash.cloudflare.com > Zero Trust > Tunnels
# สร้าง Tunnel ใหม่ > เลือก Docker > Copy token
CLOUDFLARE_TUNNEL_TOKEN=
