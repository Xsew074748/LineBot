# ════════════════════════════════════════════════════════
# IT Monitor Bot — ตัวแปรสภาพแวดล้อม
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริงก่อนรัน
# สร้างได้ผ่าน Setup UI ที่ http://localhost:3000/setup
# ════════════════════════════════════════════════════════

# ── LINE Messaging API ────────────────────────────────────
# หาได้จาก LINE Developers Console > channel > Basic settings
LINE_CHANNEL_SECRET=your_line_channel_secret_here
# หาได้จาก LINE Developers Console > channel > Messaging API > Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ── Zabbix ────────────────────────────────────────────────
# URL ของ Zabbix API เช่น http://192.168.1.10/api_jsonrpc.php
ZABBIX_URL=https://your-zabbix-server.com/api_jsonrpc.php
# API Token: Zabbix > Administration > API tokens
ZABBIX_API_TOKEN=your_zabbix_api_token_here

# ── TP-Link Omada Controller (Open API) ───────────────────
# URL ของ Omada Controller เช่น https://192.168.1.20:8043
OMADA_URL=https://your-omada-controller:8043
# Omadac ID: GET /api/info หรือดูใน Controller settings
OMADA_OMADAC_ID=your_omadac_id_here
# Site ID: ดูได้จาก URL ของ Omada หลัง /site/
OMADA_SITE_ID=your_omada_site_id_here
# Open API Client credentials: Omada > Settings > Platform Integration > Open API
OMADA_CLIENT_ID=your_omada_client_id_here
OMADA_CLIENT_SECRET=your_omada_client_secret_here
# Path ของ CA cert สำหรับ self-signed TLS (เว้นว่างถ้าใช้ cert จริง)
# Docker: ใส่ path ภายใน container เช่น /certs/omada-ca.crt
OMADA_CA_CERT_PATH=
# ตั้ง true เมื่อ cert ใช้ CN แทน SAN (ยัง verify chain — ใช้คู่กับ CA_PATH เท่านั้น)
#OMADA_TLS_SKIP_HOSTNAME=true
# Legacy web login (ไม่ใช้กับ Open API แล้ว — คงไว้เผื่อ rollback)
OMADA_USERNAME=your_omada_username_here
OMADA_PASSWORD=your_omada_password_here

# ── HikCentral (OpenAPI / artemis — AK/SK) ────────────────
# URL ของ HikCentral OpenAPI gateway เช่น https://192.168.1.30 (port 443)
HIKCENTRAL_URL=https://your-hikcentral-server
# AppKey/AppSecret: HikCentral > System > Open API > Partner (ต้อง approve + ผูก userId)
HIKCENTRAL_APP_KEY=your_hikcentral_app_key_here
HIKCENTRAL_APP_SECRET=your_hikcentral_app_secret_here
# Path ของ CA cert สำหรับ self-signed TLS (optional)
#HIKCENTRAL_CA_CERT_PATH=
#HIKCENTRAL_TLS_SKIP_HOSTNAME=true

# ── Claude AI (Anthropic) ─────────────────────────────────
# API Key: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ────────────────────────────────────────────────
# Port ที่ Bot จะรันใน process/container (Docker map เป็น 3100 ภายนอก)
PORT=3000

# ── Security ─────────────────────────────────────────────
# IP prefix ที่อนุญาตเข้า Setup UI เช่น 192.168.1. (เว้นว่างเพื่อรับทุก IP)
ALLOWED_IP_PREFIX=192.168.
# Secret สำหรับยืนยัน Zabbix Webhook — ใช้ค่าสุ่มยาวๆ เช่น openssl rand -hex 32
# ต้องตั้งค่า header  x-zabbix-secret  ฝั่ง Zabbix ให้ตรงกัน
ZABBIX_WEBHOOK_SECRET=your_random_webhook_secret_here

# ── Setup UI (optional) ───────────────────────────────────
# Password hash ของ Setup UI (SHA-256) — ตั้งได้ผ่าน Setup Wizard
# ถ้าไม่ตั้ง default password คือ "admin"
#SETUP_PASSWORD_HASH=

# ── AI Quota (optional) ──────────────────────────────────
# จำนวนครั้งที่แต่ละ user ใช้ AI ได้ต่อวัน (default: 20)
#AI_DAILY_QUOTA=20

# ── Cloudflare Tunnel (เฉพาะ tunnel แบบ token — ปัจจุบันใช้ config.yml + credentials file) ──
#CLOUDFLARE_TUNNEL_TOKEN=
